{
  "name": "@auditlayer/schema",
  "version": "0.1.0",
  "description": "AuditLayer audit log schema, Zod validators, JCS canonicalization, and SHA-256 hash chain helpers. Designed to support EU AI Act Article 12 record-keeping.",
  "license": "Apache-2.0",
  "author": "AuditLayer Contributors",
  "homepage": "https://github.com/jeffry1829/AuditLayer/tree/main/packages/schema",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffry1829/AuditLayer.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/jeffry1829/AuditLayer/issues"
  },
  "keywords": [
    "eu-ai-act",
    "article-12",
    "audit-log",
    "compliance",
    "hash-chain",
    "tamper-evident",
    "schema",
    "zod",
    "jcs",
    "rfc-8785"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./canonicalize": {
      "import": "./dist/canonicalize.js",
      "types": "./dist/canonicalize.d.ts"
    },
    "./hash-chain": {
      "import": "./dist/hash-chain.js",
      "types": "./dist/hash-chain.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7"
  }
}
